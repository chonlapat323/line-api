generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  permissions Json     @default("[]")
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         String   @default("user")
  roleId       String?
  bankName     String?
  bankAccount  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roleRef             Role?                 @relation(fields: [roleId], references: [id])
  lineGroups          UserLineGroup[]
  verificationCodes   LineVerificationCode[]
  sentLogs            LineSendLog[]         @relation("SenderLogs")
  receivedLogs        LineSendLog[]         @relation("TargetLogs")
  visitRecords        VisitRecord[]
  commissionsPaid     CommissionPayment[]   @relation("CommissionPaid")
  commissionsPaidBy   CommissionPayment[]   @relation("CommissionPaidBy")
}

model UserLineGroup {
  id          String    @id @default(cuid())
  userId      String
  lineGroupId String
  isActive    Boolean   @default(true)
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, lineGroupId])
}

model LineVerificationCode {
  id        String    @id @default(cuid())
  userId    String
  code      String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model LineSendLog {
  id           String   @id @default(cuid())
  senderId     String
  targetUserId String
  lineGroupId  String
  imageUrl     String
  details      Json
  status       String
  errorMessage String?
  createdAt    DateTime @default(now())

  sender     User @relation("SenderLogs", fields: [senderId], references: [id])
  targetUser User @relation("TargetLogs", fields: [targetUserId], references: [id])
}

model CommissionPayment {
  id      String   @id @default(cuid())
  userId  String
  month   String
  amount  Float
  paidBy  String
  note    String?
  slipUrl String?
  paidAt  DateTime @default(now())

  user  User @relation("CommissionPaid",   fields: [userId], references: [id])
  admin User @relation("CommissionPaidBy", fields: [paidBy], references: [id])

  @@unique([userId, month])
}

model VisitRecord {
  id           String   @id @default(cuid())
  userId       String
  shopName     String
  province     String
  district     String?
  latitude     Float
  longitude    Float
  tripType     String?
  customerType String
  visitType    String?
  result       String?
  details      String?
  orderAmount  Float?
  imageUrls    String[]
  slipUrl      String?
  slipStatus   String?   // "verified" | "pending_approval" | "approved" | "rejected"
  transRef     String?
  approvedBy   String?
  approvedAt   DateTime?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
